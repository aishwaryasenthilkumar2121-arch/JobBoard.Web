@model IEnumerable<JobBoard.Web.Models.Job>

<h2>Available Jobs</h2>

<a asp-action="Create">Post New Job</a>

<table class="table">
    <tr>
        <th>Job Title</th>
        <th>Company</th>
        <th>Skills</th>
        <th>Salary</th>
    </tr>

    @foreach (var job in Model)
    {
        <tr>
            <td>@job.JobTitle</td>
            <td>@job.CompanyName</td>
            <td>@job.SkillsRequired</td>
            <td>@job.Salary</td>
        </tr>
    }
</table>