@model JobBoard.Web.Models.Job

@{
    ViewData["Title"] = "Create Job";
}

<style>
    .job-container {
        max-width: 700px;
        margin: 40px auto;
    }

    .job-card {
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .job-title {
        text-align: center;
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 20px;
        color: #1e40af;
    }

    .form-label {
        font-weight: 600;
        margin-top: 10px;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px;
    }

    .btn-submit {
        width: 100%;
        padding: 12px;
        margin-top: 20px;
        border-radius: 10px;
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        font-weight: bold;
        border: none;
        transition: 0.3s;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.2);
        }
</style>

<div class="job-container">

    <div class="job-card">

        <div class="job-title">
            Post a New Job
        </div>

        <form asp-action="Create" method="post">

            <label class="form-label">Job Title</label>
            <input asp-for="JobTitle" class="form-control" placeholder="Enter job title" />
            <span asp-validation-for="JobTitle" class="text-danger"></span>

            <label class="form-label">Company Name</label>
            <input asp-for="CompanyName" class="form-control" placeholder="Enter company name" />
            <span asp-validation-for="CompanyName" class="text-danger"></span>

            <label class="form-label">Skills Required</label>
            <input asp-for="SkillsRequired" class="form-control" placeholder="Enter required skills" />
            <span asp-validation-for="SkillsRequired" class="text-danger"></span>

            <label class="form-label">Salary</label>
            <input asp-for="Salary" class="form-control" placeholder="Enter salary" />
            <span asp-validation-for="Salary" class="text-danger"></span>

            <label class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="5"
                      placeholder="Write job description"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
            <button type="submit" class="btn-submit">
                🚀 Post Job
            </button>

        </form>

    </div>

</div>